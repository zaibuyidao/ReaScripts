  [linux64       ] ReaMole/reaper_soundmole-x86_64.so    > reaper_soundmole-x86_64.so
  [linux-aarch64 ] ReaMole/reaper_soundmole-aarch64.so   > reaper_soundmole-aarch64.so
  [win64         ] ReaMole/reaper_soundmole-x64.dll      > reaper_soundmole-x64.dll
